# Database
DATABASE_URL="postgresql://user:password@localhost:5432/expose"

# AI Provider Keys
REPLICATE_API_TOKEN="your-replicate-api-token"
REPLICATE="your-replicate-token-backup"

FAL_AI="your-fal-ai-key"
FAL_KEY="your-fal-ai-key-backup"

STABILITY_API_KEY="your-stability-ai-key"

HUGGINGFACE_API_KEY="your-huggingface-api-key"

# Manus Deployment (Optional)
MANUS_API_KEY="your-manus-api-key"
MANUS_WEBHOOK_SECRET="your-manus-webhook-secret"

# Application
NODE_ENV="development"
PORT=3000
API_PORT=5000

# Authentication
SESSION_SECRET="your-session-secret-min-32-chars"

# Storage
STORAGE_TYPE="s3"
S3_BUCKET="your-bucket-name"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="your-aws-access-key"
S3_SECRET_ACCESS_KEY="your-aws-secret-key"
